# =============================================================================
# MediaHub v2 — .gitignore
# Authority: ADR-014 (reproducibility), ADR-004 (generated files are committed)
# =============================================================================
# IMPORTANT: build_runner generated files (*.g.dart, *.freezed.dart, *.drift.dart,
# pigeon-generated *.dart under packages/python_bridge/lib/) ARE committed to VCS
# per ADR-004. They are NOT in .gitignore.

# ── OS / Editor ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml

# ── Flutter / Dart ──
**/.dart_tool/
**/.flutter-plugins*
**/.packages
**/.pub-cache/
**/.pub/
**/build/
**/.fvm/flutter_sdk          # fvm downloads the SDK locally; do NOT commit
**/coverage/
.last_build_id

# Auto-generated by `flutter pub get` — regenerated on every bootstrap
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# ── Generated artifacts that are intentionally committed (NOT ignored) ──
# *.g.dart              — committed (ADR-004)
# *.freezed.dart        — committed (ADR-004)
# *.drift.dart          — committed (ADR-004)
# packages/python_bridge/lib/src/messages.g.dart — committed (ADR-008)

# BUT: transient build_runner state IS ignored
**/*.info.json
**/build_runner/

# ── Android ──
android/.gradle/
android/local.properties
android/key.properties
android/app/keystore.jks
android/app/release/*.apk
android/app/release/*.aab
android/app/build/
android/build/
android/captures/
android/.cxx/

# ── Python ──
python/__pycache__/
python/**/__pycache__/
python/.venv/
python/venv/
python/.pytest_cache/
python/**/.mypy_cache/
python/**/.ruff_cache/
python/dist/
python/build/
**/*.egg-info/
**/*.pyc

# ── Chaquopy build outputs (never commit the bundled python) ──
assets/python/**/site-packages/
assets/python/**/__pycache__/

# ── CI / secrets ──
.env
.env.*
!.env.example
*.keystore
*.jks
secrets/
gha-creds-*.json

# ── Misc ──
*.log
*.pid

# FVM Version Cache
.fvm/